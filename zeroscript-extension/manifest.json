{
  "manifest_version": 3,
  "name": "ZeroScript Free DeepSeek × Roblox Studio Agent",
  "version": "1.1.1",
  "description": "Turn DeepSeek into a Roblox Studio agent that drives Studio through a local bridge from chat.deepseek.com.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://chat.deepseek.com/*",
    "https://deepseek.com/*",
    "https://gemini.google.com/*",
    "http://127.0.0.1/*",
    "ws://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ZeroScript Free (DeepSeek)",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["core/config.js", "core/parser.js", "providers/deepseek.js", "core/main.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["core/config.js", "core/parser.js", "providers/gemini.js", "core/main.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ]
}
